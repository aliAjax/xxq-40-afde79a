#!/usr/bin/env bash
#
# Pre-commit hook: 提交前代码质量检查
# 与 scripts/check.sh 使用同一套检查逻辑，确保质量门禁一致
#
# 检查项：
#   1. JS 语法检查（仅暂存区文件）
#   2. 行尾空格检查（仅暂存区文件）
#   3. 合并冲突标记检查（仅暂存区文件）
#   4. 脚本可执行权限检查（仅暂存区文件）
#   5. 单元测试（全量）
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CHECK_SCRIPT="$PROJECT_ROOT/scripts/check.sh"

if [ ! -f "$CHECK_SCRIPT" ]; then
    echo "错误：找不到 check.sh，请确认 scripts/check.sh 存在"
    exit 1
fi

if git rev-parse --verify HEAD >/dev/null 2>&1; then
    against=HEAD
else
    against=4b825dc642cb6eb9a060e54bf8d69288fbee4904
fi

staged_files=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$staged_files" ]; then
    echo "==> 暂存区无文件，跳过检查"
    exit 0
fi

relevant_files=()
for file in $staged_files; do
    case "$file" in
        *.js|*.html|*.css|*.json|*.md|*.sh)
            if [ -f "$PROJECT_ROOT/$file" ]; then
                relevant_files+=("$file")
            fi
            ;;
    esac
done

if [ ${#relevant_files[@]} -eq 0 ]; then
    echo "==> 暂存区无待检查文件，直接运行测试..."
    echo ""
    cd "$PROJECT_ROOT"
    exec node tests/run-tests.js
fi

cd "$PROJECT_ROOT"
exec "$CHECK_SCRIPT" "${relevant_files[@]}"
